# Verplicht: 32+ willekeurige tekens. Bij migratie exact de bestaande waarde kopiëren.
MYTRADINGBOT_API_TOKEN=VERVANG_DOOR_EEN_LANG_WILLEKEURIG_GEHEIM

# Verplicht voor beta-invites/sessies: 48+ tekens. Bij migratie exact de bestaande waarde kopiëren.
MYTRADINGBOT_MASTER_KEY=VERVANG_DOOR_EEN_TWEEDE_LANG_WILLEKEURIG_GEHEIM
MYTRADINGBOT_OWNER_NAME=Eigenaar
MYTRADINGBOT_EXPECTED_INSTRUMENT=BYBIT:BTCUSDT.P
DATA_DIR=/data

# Read-only Bybit key: GEEN trade- of withdrawrechten.
BYBIT_API_KEY=
BYBIT_API_SECRET=

ANTHROPIC_API_KEY=
MYTRADINGBOT_VISION_MODEL=claude-sonnet-4-6
MYTRADINGBOT_COACH_MODEL=claude-sonnet-4-6
SUPADATA_API_KEY=
YT_CHANNEL_ID=
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
CHECK_EVERY_SEC=3600
ACCOUNT_WATCH_INTERVAL_SEC=60
BYBIT_READONLY_BASE=https://api.bytick.com
MYTRADINGBOT_ALLOWED_ORIGINS=https://beta.mytradingbot.ai
# Zet pas op 1 nadat de bronrechten en API-kosten zijn gecontroleerd.
MYTRADINGBOT_ENABLE_KNOWLEDGE_INGESTION=0
MYTRADINGBOT_ENABLE_PUBLIC_YOUTUBE_RSS=1
# Coachbronvermeldingen blijven standaard intern; zet alleen voor beheer/audit tijdelijk op 1.
MYTRADINGBOT_COACH_SHOW_SOURCES=0
# Optioneel: een persistente, gevalideerde queue op het Railway-volume.
MYTRADINGBOT_KNOWLEDGE_QUEUE=/data/knowledge_queue.json

# v8.2.2 accepteert de vorige secretnamen tijdelijk als migratie-alias.
# Laat die alleen tijdens de upgrade bestaan en verwijder ze na de groene rooktest.

# R24A - outgoing Telegram morning briefing. Disabled by default.
MYTRADINGBOT_ENABLE_TELEGRAM_DAY_START=0
MYTRADINGBOT_TELEGRAM_DAY_START_TIME=08:00
MYTRADINGBOT_TELEGRAM_DAY_START_TIMEZONE=Europe/Amsterdam
MYTRADINGBOT_TELEGRAM_DAY_START_LANGUAGE=nl
MYTRADINGBOT_TELEGRAM_DAY_START_POLL_SEC=30
MYTRADINGBOT_TELEGRAM_DAY_START_GRACE_MINUTES=120
# R24b: outgoing post-trade deepdive + one knowledge lens. Disabled by default.
MYTRADINGBOT_ENABLE_COACH_LOOP=0

# R24c: outgoing weekly mentor report. Disabled by default.
MYTRADINGBOT_ENABLE_WEEKLY_MENTOR=0
MYTRADINGBOT_WEEKLY_MENTOR_DAY=sunday
MYTRADINGBOT_WEEKLY_MENTOR_TIME=18:00
MYTRADINGBOT_WEEKLY_MENTOR_TIMEZONE=Europe/Amsterdam
MYTRADINGBOT_WEEKLY_MENTOR_LANGUAGE=nl
MYTRADINGBOT_WEEKLY_MENTOR_POLL_SEC=60
MYTRADINGBOT_WEEKLY_MENTOR_GRACE_MINUTES=180

# R25B Commitment Mode / account-hekken. Een deploy activeert niets.
MYTRADINGBOT_COMMITMENT_MAX_DAILY_LOSS_PCT=2.0
MYTRADINGBOT_REVENGE_COOLDOWN_MINUTES=30
MYTRADINGBOT_ENABLE_R_BREACH_TELEGRAM=0
# R25C journal pattern suggestions (rules always require an explicit owner click)
MYTRADINGBOT_PATTERN_MIN_REPETITIONS=4
MYTRADINGBOT_PATTERN_MIN_LOSS_RATE=0.65
MYTRADINGBOT_PATTERN_SUGGESTION_TTL_DAYS=14
MYTRADINGBOT_ENABLE_PATTERN_SUGGESTION_TELEGRAM=0
